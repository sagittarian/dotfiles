[global_config]
  focus = mouse
  enabled_plugins = CustomCommandsMenu, InactivityWatch, ActivityWatch, TerminalShot, LaunchpadCodeURLHandler, APTURLHandler, Logger, LaunchpadBugURLHandler
[keybindings]
  go_up = <Alt>t
  go_down = <Alt>n
  go_left = <Alt>h
  go_right = <Alt>s
  toggle_scrollbar = <Shift><Alt>s
  page_up = <Alt>v
  page_down = <Primary>v
  close_window = <Primary><Shift>q
  next_tab = <Primary><Shift>s
  prev_tab = <Primary><Shift>h
  layout_launcher = <Shift><Alt>l
[profiles]
  [[default]]
    visible_bell = True
    urgent_bell = True
    font = DejaVu Sans Mono 14
    scrollback_infinite = True
    login_shell = True
    use_system_font = False
  [[small]]
    font = DejaVu Sans Mono 10
    scrollback_infinite = True
    use_system_font = False
    use_theme_colors = True
[layouts]
  [[default]]
    [[[child1]]]
      parent = window0
      profile = default
      type = Terminal
    [[[window0]]]
      parent = ""
      type = Window
[plugins]
